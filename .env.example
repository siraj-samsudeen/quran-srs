# Database Configuration
# ======================

# SQLite (default - leave DATABASE_URL empty or omit this file)
# DATABASE_URL=

# PostgreSQL (local development)
# DATABASE_URL=postgresql://localhost/quran_srs_dev

# PostgreSQL (with authentication)
# DATABASE_URL=postgresql://username:password@localhost:5432/quran_srs_dev

# PostgreSQL (production example)
# DATABASE_URL=postgresql://user:password@db.example.com:5432/quran_srs_prod

# Application Settings
# ====================
BASE_URL=http://localhost:5001
